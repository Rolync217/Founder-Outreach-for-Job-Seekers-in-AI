# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/outreach

# Required when using Docker Compose — must match the password in DATABASE_URL above.
POSTGRES_PASSWORD=changeme

# ── AI / LLM ──────────────────────────────────────────────────────────────────
# Use your OpenRouter key here — the Anthropic SDK routes automatically via ANTHROPIC_BASE_URL
ANTHROPIC_API_KEY=sk-or-v1-...
ANTHROPIC_BASE_URL=https://openrouter.ai/api

# ── Sourcing & research tools ─────────────────────────────────────────────────
FIRECRAWL_API_KEY=fc-...         # web scraping (sourcing + research nodes + MCP server)
LINKDAPI_KEY=li-...              # LinkedIn posts (hiring signals via MCP server)

# ── Optional: LangSmith tracing ───────────────────────────────────────────────
LANGSMITH_API_KEY=ls__...
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=outreach-pipeline
