# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/outreach

# Required when using Docker Compose — must match the password in DATABASE_URL above.
POSTGRES_PASSWORD=changeme

# ── AI / LLM ──────────────────────────────────────────────────────────────────
# Set ONE of the following — whichever provider you chose during setup.
# Model strings in config.yaml must use the matching prefix (see README).

# OpenRouter (recommended — one key covers all providers, 200+ models)
# Get your key at: openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Anthropic direct (if you have a direct Anthropic API key)
# Get your key at: console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# Moonshot / Kimi direct (if you have direct Moonshot credits)
# Get your key at: platform.moonshot.cn
# MOONSHOT_API_KEY=...

# OpenAI direct
# Get your key at: platform.openai.com
# OPENAI_API_KEY=sk-...

# ── Sourcing & research tools ─────────────────────────────────────────────────
FIRECRAWL_API_KEY=fc-...         # web scraping (sourcing + research nodes + MCP server)
LINKDAPI_KEY=li-...              # LinkedIn posts (hiring signals via MCP server)

# ── Optional: LangSmith tracing ───────────────────────────────────────────────
LANGSMITH_API_KEY=ls__...
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=outreach-pipeline
